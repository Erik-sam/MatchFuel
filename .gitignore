# =============================================
# MatchFuel - .gitignore
# Project is pure static HTML/CSS/JS (no build, no Node.js).
# Layout:
#   MatchFuel/   application source (tracked)
#   data/        sample_players.json (tracked)
#   docs/        .docx / .pptx / .md deliverables (tracked)
#                  -> only Office lock files (~$*.docx, ~$*.pptx) are ignored
#   scripts/     build pipeline .ps1 files (tracked)
#                  -> only *.ps1.bak backups are ignored
# =============================================

# ---------- Operating system ----------
# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Linux
*~
.directory
.Trash-*

# ---------- Editors / IDEs ----------
# VS Code (track shared settings, ignore per-user noise)
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/launch.json
.history/

# JetBrains
.idea/
*.iml
*.iws

# Sublime
*.sublime-project
*.sublime-workspace

# Vim / Emacs
*.swp
*.swo
*~
\#*\#
.\#*

# ---------- Microsoft Office lock files ----------
# Word / PowerPoint create these in docs/ while the file is open.
# The patterns below match anywhere in the tree, including docs/.
~$*.docx
~$*.pptx
~$*.xlsx
~$*.doc
~$*.ppt
~WRL*.tmp
docs/~$*

# ---------- Node / npm (defensive - project has no real deps but package.json exists) ----------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
.pnpm-debug.log*

# ---------- Logs and temp ----------
*.log
*.tmp
*.temp
*.bak
*.old
*.orig

# ---------- PowerShell ----------
# Build pipeline lives in scripts/ (tracked).
# Ignore only backups and any transcript output.
*.ps1.bak
scripts/*.bak
PowerShell_transcript.*.txt

# ---------- Browser / dev ----------
.cache/
.parcel-cache/
.firebase/
.netlify/

# ---------- Local-only / secrets ----------
.env
.env.local
*.local
secrets.json
